{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "TerrainPrototype",
    "version":  "0.1.0",
    "identifier":  "com.marcbielert.terrainprototype",
    "build":  {
                  "frontendDist":  "../.tauri-dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "TerrainPrototype",
                                    "width":  800,
                                    "height":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "minWidth":  800,
                                    "minHeight":  600
                                }
                            ],
                "security":  {
                                 "csp":  "default-src 'self' asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: file: blob:; connect-src 'self' ipc: http://ipc.localhost file:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
